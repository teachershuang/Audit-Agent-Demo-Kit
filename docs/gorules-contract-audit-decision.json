            "input_condition": "derived.hasBreachClause == false",
            "output_config_id": "\"config_rule_missing_breach_clause\"",
            "output_rule_id": "\"missing_breach_clause\"",
            "output_rule_name": "\"违约责任条款缺失\"",
            "output_severity": "\"medium\"",
            "output_decision": "\"hit\"",
            "output_reason": "\"未识别到违约责任条款，建议核查合同责任约束是否完整。\"",
            "output_depends_on": "[\"违约责任\"]",
            "output_evidence_clause_ids": "[]"
          },
          {
            "_id": "rule_missing_account_info",
